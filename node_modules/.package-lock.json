{
  "name": "sysutils-monorepo",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "node_modules/@sysutils/ps": {
      "resolved": "packages/ps",
      "link": true
    },
    "node_modules/@sysutils/ps-dotnet": {
      "resolved": "packages/ps-dotnet",
      "link": true
    },
    "packages/ps": {
      "name": "@sysutils/ps",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@sysutils/ps-dotnet": "^0.1.0"
      }
    },
    "packages/ps-dotnet": {
      "name": "@sysutils/ps-dotnet",
      "version": "0.1.0",
      "cpu": [
        "x64",
        "arm64"
      ],
      "license": "MIT",
      "os": [
        "win32",
        "linux",
        "darwin"
      ]
    }
  }
}
